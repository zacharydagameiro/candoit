SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Preferred for deployed environments:
PI_SEARCH_ENDPOINT=
PI_SEARCH_API_KEY=

# Local host bridge from Dockerized edge runtime:
LOCAL_PI_SERVER_URL=http://host.docker.internal:8787/find-suppliers

# Local-only fallback for running `pi` on the same machine:
ALLOW_LOCAL_PI_COMMAND=false

# Optional extra protection when verify_jwt=false:
FIND_SUPPLIERS_SHARED_SECRET=
